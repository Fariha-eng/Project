{
  "version": 2,
  "builds": [
    {
      "src": "smart-queue/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend-folder/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-folder/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "smart-queue/dist/index.html"
    }
  ]
}